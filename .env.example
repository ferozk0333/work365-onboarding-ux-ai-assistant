# Copy this file to .env and fill in your values

# ── LLM ──────────────────────────────────────────────────────────────────────
# Provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY="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"     # also used for embeddings

# ── Embeddings ────────────────────────────────────────────────────────────────
# Provider: "openai" or "voyage"
# OpenAI  → needs OPENAI_API_KEY above, uses text-embedding-3-small (1536-dim)
# Voyage  → needs VOYAGE_API_KEY below, uses voyage-3-lite (1024-dim)
EMBEDDING_PROVIDER=openai
VOYAGE_API_KEY=your-voyage-api-key-here      # only needed if EMBEDDING_PROVIDER=voyage

# ── RAG tuning ────────────────────────────────────────────────────────────────
RAG_TOP_K=4
RAG_MIN_SCORE=0.35
CHUNK_SIZE=2000
CHUNK_OVERLAP=200
